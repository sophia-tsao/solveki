# Python
**/__pycache__/
*.py[cod]

# Local environment files (secrets / machine-specific config)
.env
*.env

# Django
# The SQLite dev database is machine-local; don't track it.
backend/db.sqlite3
# Runtime server logs are regenerated on each run; don't track them.
backend/*.log

# Frontend
node_modules/
frontend/dist/

# Playwright (E2E) artifacts and the saved test session
frontend/playwright-report/
frontend/test-results/
frontend/e2e/.auth/
